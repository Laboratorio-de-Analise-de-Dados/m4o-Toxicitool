\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Fluxograma metodológico geral do \textit  {pipeline} ToxiciTOOL. O processo é estruturado em três macroetapas sequenciais: \textbf  {(A)} Pré-processamento e curadoria da base de dados bruta, culminando na canonização e fusão das vias de exposição; \textbf  {(B)} Engenharia de características (extração de \textit  {fingerprints} e descritores ADME), particionamento estrutural para mitigação de vazamento de dados, e treinamento da arquitetura de \textit  {Multi-Task Learning} (MTL); e \textbf  {(C)} Validação cruzada iterativa e geração padronizada de artefatos visuais e métricas de desempenho preditivo.}}{13}{figure.caption.5}\protected@file@percent }
\newlabel{fig:pipeline_geral}{{2}{13}{Fluxograma metodológico geral do \textit {pipeline} ToxiciTOOL. O processo é estruturado em três macroetapas sequenciais: \textbf {(A)} Pré-processamento e curadoria da base de dados bruta, culminando na canonização e fusão das vias de exposição; \textbf {(B)} Engenharia de características (extração de \textit {fingerprints} e descritores ADME), particionamento estrutural para mitigação de vazamento de dados, e treinamento da arquitetura de \textit {Multi-Task Learning} (MTL); e \textbf {(C)} Validação cruzada iterativa e geração padronizada de artefatos visuais e métricas de desempenho preditivo}{figure.caption.5}{}}
